---
import '../styles/global.css';
import ThemeVars from '../components/ThemeVars.astro';
import JsonLd from '../components/JsonLd.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import type { PageMeta } from '../lib/seo/buildGraph';

const { title, description, page } = Astro.props as {
  title: string;
  description: string;
  page: PageMeta;
  bodyClass?: string;
};

const fullTitle = `${title} | Brand Semantics`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={page.url} />
    <slot name="head" />
    <ThemeVars />
    <JsonLd page={page} />
  </head>
  <body class={`bg-background text-ink ${Astro.props.bodyClass ?? ""}`.trim()}>
    <SiteHeader />
    <main class="pt-20">
      <slot />
    </main>
    <SiteFooter />
    <script is:inline>
      (() => {
        const prefersReducedMotion =
          !!window.matchMedia?.("(prefers-reduced-motion: reduce)")?.matches;
        if (prefersReducedMotion) return;

        const MIN_DURATION_MS = 650;
        const MAX_DURATION_MS = 2200;
        const SPEED_PX_PER_MS = 0.9;

        const easeInOutCubic = (t) =>
          t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;

        const clamp = (value, min, max) => Math.min(max, Math.max(min, value));
        const getScrollMarginTopPx = (node) => {
          try {
            const raw = window.getComputedStyle(node).scrollMarginTop || "0";
            const parsed = Number.parseFloat(raw);
            return Number.isFinite(parsed) ? parsed : 0;
          } catch {
            return 0;
          }
        };

        const docEl = document.documentElement;
        const body = document.body;
        const prevDocScrollBehavior = docEl.style.scrollBehavior;
        const prevBodyScrollBehavior = body?.style?.scrollBehavior ?? "";

        const setManualScrollMode = (enabled) => {
          // Prevent CSS `scroll-behavior: smooth` from interfering with our rAF animation.
          if (enabled) {
            docEl.style.scrollBehavior = "auto";
            if (body) body.style.scrollBehavior = "auto";
          } else {
            docEl.style.scrollBehavior = prevDocScrollBehavior;
            if (body) body.style.scrollBehavior = prevBodyScrollBehavior;
          }
        };

        let rafId = null;
        let cancelActiveScroll = null;
        const animateScrollTo = (targetY) => {
          if (rafId) cancelAnimationFrame(rafId);
          cancelActiveScroll?.();
          cancelActiveScroll = null;

          const startY = window.scrollY || window.pageYOffset || 0;
          const maxY = Math.max(
            0,
            (document.documentElement?.scrollHeight || 0) - window.innerHeight,
          );
          const clampedTargetY = Math.min(Math.max(0, targetY), maxY);
          const delta = clampedTargetY - startY;
          if (Math.abs(delta) < 1) {
            window.scrollTo(0, clampedTargetY);
            return;
          }

          const durationMs = clamp(
            Math.abs(delta) / SPEED_PX_PER_MS,
            MIN_DURATION_MS,
            MAX_DURATION_MS,
          );
          const startTime = performance.now();
          setManualScrollMode(true);

          const end = () => {
            if (rafId) cancelAnimationFrame(rafId);
            rafId = null;
            setManualScrollMode(false);
            cancelActiveScroll = null;
          };

          const onUserIntent = () => end();
          window.addEventListener("wheel", onUserIntent, { passive: true });
          window.addEventListener("touchstart", onUserIntent, { passive: true });
          window.addEventListener("keydown", onUserIntent);
          cancelActiveScroll = () => {
            window.removeEventListener("wheel", onUserIntent);
            window.removeEventListener("touchstart", onUserIntent);
            window.removeEventListener("keydown", onUserIntent);
            end();
          };

          const tick = (now) => {
            const elapsed = now - startTime;
            const t = Math.min(1, elapsed / durationMs);
            const eased = easeInOutCubic(t);
            window.scrollTo(0, startY + delta * eased);
            if (t < 1) {
              rafId = requestAnimationFrame(tick);
            } else {
              // Snap to the exact final position to avoid sub-pixel drift.
              window.scrollTo(0, clampedTargetY);
              cancelActiveScroll?.();
            }
          };

          rafId = requestAnimationFrame(tick);
        };

        document.addEventListener("click", (event) => {
          if (event.defaultPrevented) return;
          if (event.button !== 0) return;
          if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey)
            return;

          const anchor = event.target?.closest?.('a[href^="#"]');
          if (!(anchor instanceof HTMLAnchorElement)) return;
          if (anchor.target && anchor.target !== "_self") return;

          const href = anchor.getAttribute("href") || "";
          if (!href.startsWith("#")) return;

          const rawId = href.slice(1);
          const id = rawId ? (() => { try { return decodeURIComponent(rawId); } catch { return rawId; } })() : "";
          const target = id ? document.getElementById(id) : document.body;
          if (!target) return;

          event.preventDefault();

          const rect = target.getBoundingClientRect();
          const targetY =
            (window.scrollY || window.pageYOffset || 0) +
            rect.top -
            (id ? getScrollMarginTopPx(target) : 0);
          animateScrollTo(targetY);

          if (id) {
            history.pushState(null, "", `#${encodeURIComponent(id)}`);
          } else {
            history.pushState(null, "", window.location.pathname + window.location.search);
          }
        });
      })();
    </script>
  </body>
</html>
