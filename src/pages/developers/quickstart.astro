---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_URL } from '../../lib/seo/site';

const title = 'Developer Quickstart';
const description = 'A minimal workflow for integrating IBOM™ into product systems.';

const page = {
  title,
  description,
  url: `${SITE_URL}/developers/quickstart`,
  breadcrumbs: [
    { name: 'Home', url: `${SITE_URL}/` },
    { name: 'Developers', url: `${SITE_URL}/developers` },
    { name: 'Quickstart', url: `${SITE_URL}/developers/quickstart` }
  ]
};
---
<BaseLayout title={title} description={description} page={page}>
  <section class="container-wide py-16">
    <div class="eyebrow">Developers</div>
    <h1 class="mt-4 text-4xl font-semibold text-ink">Quickstart</h1>
    <p class="mt-4 text-base text-steel">
      Use IBOM™ as a policy layer between brand intent and execution. Model the brand as structured schemas (meaning,
      terminology, tone, accessibility, approvals), then encode those expectations as checks that run in CI before changes
      ship. Once that’s stable, expose the same policy to runtime workflows via MCP for consistent enforcement across tools.
    </p>
  </section>

  <section class="container-wide pb-20">
    <div class="prose">
      <h2>1. Define semantic schemas</h2>
      <pre><code>{`{
  "brand": "Brand Semantics",
  "principles": ["Code", "Accessible", "Structured"],
  "policy": {
    "voice": "systems-first",
    "approvals": ["brand-governance"]
  }
}`}</code></pre>

      <h2>2. Encode control policies</h2>
      <pre><code>{`{
  "rules": [
    { "id": "tone.systems", "enforce": true },
    { "id": "accessibility.altText", "enforce": true }
  ]
}`}</code></pre>

      <h2>3. Deploy through MCP</h2>
      <p>
        Expose your checks as an MCP tool so any agent or workflow can ask for validation before publishing, shipping, or
        approving changes.
      </p>
      <pre><code>{`// server.ts (minimal MCP "validate" tool)
import { Server } from "@modelcontextprotocol/sdk/server/index.js";
import { StdioServerTransport } from "@modelcontextprotocol/sdk/server/stdio.js";
import { z } from "zod";

// Replace these with your real IBOM loader + rules engine.
const loadPolicy = async () => ({ rules: ["tone.systems", "accessibility.altText"] });
const validate = async (text: string, policy: { rules: string[] }) => ({
  ok: true,
  policy: policy.rules,
  notes: ["Example: wire this to your real checks"],
});

const server = new Server(
  { name: "ibom-policy", version: "0.1.0" },
  { capabilities: { tools: {} } }
);

server.tool(
  "ibom.validate",
  { text: z.string() },
  async ({ text }) => validate(text, await loadPolicy())
);

await server.connect(new StdioServerTransport());`}</code></pre>
    </div>
  </section>
</BaseLayout>
