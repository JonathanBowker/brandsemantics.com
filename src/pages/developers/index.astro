---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_URL } from '../../lib/seo/site';

const title = 'Developers';
const description = 'Implementation entrypoints for IBOM™ and brand governance systems.';

const page = {
  title,
  description,
  url: `${SITE_URL}/developers`,
  breadcrumbs: [
    { name: 'Home', url: `${SITE_URL}/` },
    { name: 'Developers', url: `${SITE_URL}/developers` }
  ]
};
---
<BaseLayout title={title} description={description} page={page}>
  <section class="container-wide py-16">
    <div class="eyebrow">Developers</div>
    <h1 class="mt-4 text-4xl font-semibold text-ink">Build on governed brand systems</h1>
    <p class="mt-4 text-base text-steel">
      IBOM™ provides schemas, policies, and interfaces that developers can integrate into product workflows.
    </p>

    <h2 class="mt-12 text-2xl font-semibold tracking-tight text-ink">
      Teach your brand to:
    </h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {[
        {
          title: 'Apply policy',
          body: 'Run deterministic rules in pipelines and AI tooling.'
        },
        {
          title: 'Stay versioned',
          body: 'Track changes, approvals, and exceptions over time.'
        },
        {
          title: 'Explain decisions',
          body: 'Make outcomes reviewable and auditable by design.'
        },
        {
          title: 'Measure drift',
          body: 'Detect misalignment and trigger controlled updates.'
        }
      ].map((item) => (
        <div class="rounded-2xl border border-fog bg-surface p-6 shadow-outline">
          <div class="text-xs font-semibold tracking-[0.2em] uppercase text-steel">{item.title}</div>
          <p class="mt-3 text-sm leading-relaxed text-steel">{item.body}</p>
        </div>
      ))}
    </div>
  </section>
  <section class="container-wide pb-20">
    <div class="grid gap-6 lg:grid-cols-2">
      <a href="/developers/quickstart" class="rounded-xl border border-fog bg-surface p-6">
        <div class="text-sm font-semibold text-ink">Quickstart</div>
        <p class="mt-3 text-sm text-steel">Bootstrap IBOM™ compliance with a minimal workflow.</p>
      </a>
      <a href="/developers/mcp-servers" class="rounded-xl border border-fog bg-surface p-6">
        <div class="text-sm font-semibold text-ink">MCP Servers</div>
        <p class="mt-3 text-sm text-steel">Policy-aware interfaces for brand governance automation.</p>
      </a>
    </div>
  </section>
</BaseLayout>
