---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE_URL } from "../lib/seo/site";
import usesPurposeUnderstandingImg from "../components/uses/assessment.svg?url";
import usesSystemFramingImg from "../components/uses/frame.svg?url";
import usesSpecificationDesignImg from "../components/uses/codification.svg?url";
import usesValidationEvaluationImg from "../components/uses/evaluation.svg?url";
import usesExecutionGenerationImg from "../components/uses/operation.svg?url";
import usesDeploymentOperationalUseImg from "../components/uses/optimisation.svg?url";
import usesRevisionGovernanceImg from "../components/uses/definition.svg?url";

const title = "Intelligent Business Operating Model (IBOM<sup>®</sup>)";
const description =
  "Turn business logic into governed, executable infrastructure for AI systems — starting with brand governance.";
const usesTabs = [
  {
  key: "purpose_understanding",
  label: "1. Purpose",
  lead: "Phase 1",
  heading: "PURPOSE UNDERSTANDING",
  subheading: "Define business purpose, outcomes, and constraints.",
  body: "Establish the business purpose, strategic objectives, success criteria, and operating constraints for the AI system. This phase ensures all subsequent work is anchored to real business outcomes rather than technical enthusiasm alone. By the end of this phase, stakeholders share a documented understanding of what the system must achieve, how success will be measured, and what boundaries must be respected.",
  href: "#get-in-touch",
  cta: "Get in touch",
  image: usesPurposeUnderstandingImg,
},
{
  key: "system_framing",
  label: "2. Frame",
  lead: "Phase 2",
  heading: "SYSTEM FRAMING",
  subheading: "Define the knowledge, sources, actors, and operating context.",
  body: "Identify and validate the business knowledge, source materials, rules, subject matter expertise, tools, and integrations that will shape the system. This phase establishes the authoritative context, operating boundaries, and technical landscape within which the AI system will function. By the end of this phase, the foundations for specification and implementation are clear, credible, and ready to be used.",
  href: "#get-in-touch",
  cta: "Get in touch",
  image: usesSystemFramingImg,
},
{
  key: "specification_design",
  label: "3. Specify",
  lead: "Phase 3",
  heading: "SPECIFICATION DESIGN",
  subheading: "Turn business logic into machine-operable specifications.",
  body: "Translate business rules, expert judgment, processes, and policies into structured technical specifications that AI systems can interpret, reason over, and act upon. This is the shift at the heart of IBOM: specification becomes the primary operating mechanism for governed AI development. By the end of this phase, business intent has been transformed into a precise and usable foundation for system design and execution.",
  href: "#get-in-touch",
  cta: "Get in touch",
  image: usesSpecificationDesignImg,
},
{
  key: "execution_generation",
  label: "4. Build",
  lead: "Phase 4",
  heading: "EXECUTION / GENERATION",
  subheading: "Design and build governed AI systems.",
  body: "Use the approved specifications to supervise the AI-assisted design, build, and implementation of practical systems. This phase turns structured business logic into applications, agents, workflows, and tools that can operate within clear governance boundaries. By the end of this phase, working systems are in place and ready to move through structured validation and operational review.",
  href: "#get-in-touch",
  cta: "Get in touch",
  image: usesExecutionGenerationImg,
},
{
  key: "validation_evaluation",
  label: "5. Validate",
  lead: "Phase 5",
  heading: "VALIDATE / EVALUATE",
  subheading: "Test safety, accuracy, performance, and policy adherence.",
  body: "Validate that the system performs as intended against business objectives, operational rules, and governance requirements. This includes testing for quality, safety, edge cases, compliance, and specification fidelity before live deployment. By the end of this phase, you have clear evidence that the system is ready for production use within defined operational and governance thresholds.",
  href: "#get-in-touch",
  cta: "Get in touch",
  image: usesValidationEvaluationImg,
},
{
  key: "deployment_operational_use",
  label: "6. Deploy",
  lead: "Phase 6",
  heading: "DEPLOY / OPERATE",
  subheading: "Deploy with control, monitoring, and live governance.",
  body: "Deploy the system into production with clear controls, monitoring, and operational oversight. This phase ensures the system can be used confidently in live environments while maintaining transparency, traceability, and performance at scale. By the end of this phase, the system is operating in the real world with the visibility and discipline needed for trustworthy ongoing use.",
  href: "#get-in-touch",
  cta: "Get in touch",
  image: usesDeploymentOperationalUseImg,
},
{
  key: "revision_governance",
  label: "7. Govern",
  lead: "Phase 7",
  heading: "REVISION / GOVERNANCE",
  subheading: "Continuously refine the system as needs evolve.",
  body: "Maintain the system through structured review, revision, and governance. As business needs, risks, models, and environments change, specifications and implementations are updated in a controlled way so the operating model remains aligned, effective, and trustworthy. By the end of this phase, improvement becomes continuous and governance becomes part of how the system evolves over time.",
  href: "#get-in-touch",
  cta: "Get in touch",
  image: usesRevisionGovernanceImg,
},
] as const;
const defaultUsesKey = usesTabs[0].key;
const page = {
  title,
  description,
  url: `${SITE_URL}/`,
  breadcrumbs: [{ name: "Home", url: `${SITE_URL}/` }],
};
---

<BaseLayout title={title} description={description} page={page}>
  <!-- 1. HERO -->
  <section
    class="relative overflow-hidden bg-slate text-paper min-h-[calc(100vh-5rem)]"
  >
    <div
      class="container-wide relative z-10 pt-[9.5rem] pb-[8.5rem] lg:pt-[10.5rem] lg:pb-[9.5rem]"
    >
      <div class="grid gap-12 lg:items-center">
        <div>
          <div class="eyebrow mb-12 text-base text-paper/80">
            Knowledge-first. Expert-led. AI-assisted.
          </div>
          <h1
            class="font-masthead text-[clamp(2.95rem,5.6vw,5.15rem)] font-semibold tracking-tight text-paper leading-[1] max-w-[52rem] md:max-w-[56rem]"
          >
            Intelligent business operations
          </h1>
          <h2
            class="mt-3 font-masthead text-[clamp(2rem,4.2vw,3.35rem)] font-semibold tracking-tight text-paper leading-[1] max-w-[52rem] md:max-w-[56rem]"
          >
            Turn your business knowledge into governed AI systems that work
          </h2>

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              href="#get-in-touch"
              class="inline-flex items-center justify-center gap-2 rounded-md bg-[#ef27f4] px-6 py-3 text-xs font-semibold leading-none tracking-[0.14em] uppercase text-paper shadow-outline transition-colors hover:bg-[#d823dd]"
            >
              Get in touch
              <svg
                class="h-4 w-4"
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M4 10h12"></path>
                <path d="M12 6l4 4-4 4"></path>
              </svg>
            </a>
            <a
              href="#why"
              class="inline-flex items-center justify-center gap-3 rounded-md border border-[#ff8c69] px-6 py-3 text-xs font-semibold tracking-[0.14em] uppercase text-[#ff8c69] transition-colors hover:bg-[#ff8c69] hover:text-paper"
            >
              <span>Keep Exploring</span>
              <svg
                class="h-5 w-5"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M10 3a1 1 0 0 1 1 1v10.586l2.293-2.293a1 1 0 1 1 1.414 1.414l-4.007 4.007a1 1 0 0 1-1.414 0L6.279 13.707a1 1 0 1 1 1.414-1.414L10 14.586V4a1 1 0 0 1 1-1z"
                ></path>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. WHY IBOM -->
  <section id="why" class="bg-paper">
    <div class="container-wide py-20">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <h2
            class="text-[clamp(2.5rem,5vw,4.75rem)] font-semibold tracking-tight text-ink"
          >
            We transform knowledge into AI-ready infrastructure
          </h2>
        </div>

        <div class="max-w-prose text-lg leading-relaxed text-steel md:text-xl">
          <p>
            Many organisations invest in AI tools to improve operations, but
            struggle to make them interoperate. Business logic, knowledge bases,
            brand guidelines, compliance policies, and operational procedures
            live in documents and tacit knowledge, making them inaccessible to
            systems.
          </p>
          <p class="mt-6">
            <b>The Intelligent Business Operating Model (IBOM<sup>®</sup>)</b> helps
            businesses transform logic into executable infrastructure. Starting with
            brand governance and expanding into compliance, operations, and beyond,
            we codify policies to make governance enforceable across AI workflows.
          </p>
        </div>
      </div>
      <div class="mt-12 flex items-center justify-center">
        <a
          href="#concerns"
          class="inline-flex items-center justify-center gap-3 rounded-md bg-[#ff8c69] px-8 py-3 text-sm font-semibold tracking-[0.14em] uppercase text-paper shadow-outline hover:bg-[#e97d5d] transition-colors"
          aria-label="Explore the next section"
        >
          <span>Keep Exploring</span>
          <svg
            class="h-6 w-6 text-paper"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M10 3a1 1 0 0 1 1 1v10.586l2.293-2.293a1 1 0 1 1 1.414 1.414l-4.007 4.007a1 1 0 0 1-1.414 0L6.279 13.707a1 1 0 1 1 1.414-1.414L10 14.586V4a1 1 0 0 1 1-1z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section id="concerns" class="bg-slate text-paper">
    <div class="container-wide py-20">
      <h2
        class="text-center text-[clamp(2.5rem,5vw,4.75rem)] font-semibold tracking-tight text-paper"
      >
        How We Work
      </h2>
      <p
        class="mx-auto mt-10 max-w-[90ch] text-lg leading-relaxed text-paper/80 md:text-xl"
      >
        Regardless of project domain or theme, our approach is always the same:
        we begin with your business knowledge, apply expert judgment, and use AI
        to accelerate delivery under clear human supervision.
      </p>
      <p
        class="mx-auto mt-6 max-w-[90ch] text-lg leading-relaxed text-paper/80 md:text-xl"
      >
        We bring the AI expertise needed to transform your business knowledge,
        rules, and expert specifications into the technical foundation required
        to design, build, and govern AI with precision.
      </p>

        <div class="mt-14 grid gap-4 lg:grid-cols-3">
          <div
            class="rounded-2xl border border-paper/15 bg-ink/30 p-6 shadow-outline backdrop-blur"
          >
          
            <h4 class="text-lg font-semibold tracking-tight text-paper">
              Knowledge-first discovery
            </h4>
            <p class="mt-3 text-base leading-relaxed text-paper/75 md:text-lg">
              We work with your teams to capture business workflow processes,
              documents, data, and bottlenecks so the system is shaped around
              the actual workings of your organisation.
            </p>
          </div>
          <div
            class="rounded-2xl border border-paper/15 bg-ink/30 p-6 shadow-outline backdrop-blur"
          >
          
            <h4 class="text-lg font-semibold tracking-tight text-paper">
              Expert-led specifications
            </h4>
            <p class="mt-3 text-base leading-relaxed text-paper/75 md:text-lg">
              We bring the right expertise together in an AI-assisted workspace
              to define system requirements and instructions in a format experts
              can validate and AI agents can act on.
            </p>
          </div>
          <div
            class="rounded-2xl border border-paper/15 bg-ink/30 p-6 shadow-outline backdrop-blur"
          >
          
            <h4 class="text-lg font-semibold tracking-tight text-paper">
              AI-assisted delivery
            </h4>
            <p class="mt-3 text-base leading-relaxed text-paper/75 md:text-lg">
              We move these specifications into an integrated development
              environment, supervising AI-assisted building, testing,
              deployment, and management at the speed of thought.
            </p>
          </div>
      </div>

      <div class="mt-16 border-t border-paper/10 pt-16">
        <h3
          class="text-center text-3xl font-semibold tracking-tight text-paper md:text-4xl"
        >
          Two connected phases
        </h3>
        <p
          class="mx-auto mt-6 max-w-[90ch] text-center text-lg leading-relaxed text-paper/80 md:text-xl"
        >
          The first phase captures and structures your business knowledge into
          governed datasets your organisation owns. The second connects that
          knowledge to the AI systems you use so it can be found, trusted, and
          acted on.
        </p>
      </div>

      <div class="mt-12 grid gap-10 lg:grid-cols-2">
        <div
          class="rounded-2xl border border-paper/15 bg-ink/30 p-10 shadow-outline backdrop-blur"
        >
          <div
            class="text-lg font-semibold tracking-[0.2em] uppercase text-[#ef27f4]"
          >
            Phase 1
          </div>
          <div class="mt-4 text-2xl font-semibold tracking-tight text-paper">
            Knowledge Base Build
          </div>
          <div
            class="mt-4 text-base font-medium leading-relaxed text-paper/80 md:text-lg"
          >
            <p>
              We work with your subject matter experts to capture what your
              organisation knows: its rules, processes, decisions, and
              expertise, then turn that knowledge into structured,
              machine-readable datasets your business owns outright rather than
              locking it into a platform.
            </p>
            <ul class="mt-6 space-y-4 text-paper/75">
              <li class="flex gap-3">
                <span
                  class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-[#ef27f4]"
                ></span>
                <span>
                  Capture specialist knowledge, business rules, and operational
                  reality through workshops, interviews, and expert input.
                </span>
              </li>
              <li class="flex gap-3">
                <span
                  class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-[#ef27f4]"
                ></span>
                <span>
                  Structure that knowledge into governed datasets, documents,
                  and interlinked records that AI systems can read, search, and
                  reason over.
                </span>
              </li>
              <li class="flex gap-3">
                <span
                  class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-[#ef27f4]"
                ></span>
                <span>
                  Create a portable knowledge base that can feed directly into
                  your API and MCP delivery layer.
                </span>
              </li>
            </ul>
          </div>
        </div>

        <div
          class="rounded-2xl border border-paper/15 bg-ink/30 p-10 shadow-outline backdrop-blur"
        >
          <div
            class="text-lg font-semibold tracking-[0.2em] uppercase text-[#ef27f4]"
          >
            Phase 2
          </div>
          <div class="mt-4 text-2xl font-semibold tracking-tight text-paper">
            API &amp; MCP Delivery
          </div>
          <div
            class="mt-4 text-base font-medium leading-relaxed text-paper/80 md:text-lg"
          >
            <p>
              We build the retrieval and connection layer that makes your
              knowledge accessible to any AI system, whether that is ChatGPT,
              Microsoft Copilot, internal agents, or your own operational
              tooling. Your knowledge becomes a live, queryable service AI can
              call on demand.
            </p>
            <ul class="mt-6 space-y-4 text-paper/75">
              <li class="flex gap-3">
                <span
                  class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-[#ef27f4]"
                ></span>
                <span>
                  Design and build the retrieval architecture that finds the
                  right knowledge at the right moment, accurately and at scale.
                </span>
              </li>
              <li class="flex gap-3">
                <span
                  class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-[#ef27f4]"
                ></span>
                <span>
                  Wrap your knowledge base in a governed API and MCP server
                  network so any AI tool can connect through a secure,
                  standardised interface.
                </span>
              </li>
              <li class="flex gap-3">
                <span
                  class="mt-1 h-2.5 w-2.5 shrink-0 rounded-full bg-[#ef27f4]"
                ></span>
                <span>
                  Deliver working AI services, internal tools, and live
                  workflows powered by your knowledge with governance and
                  oversight built in.
                </span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <p
        class="mx-auto mt-12 max-w-[90ch] text-lg leading-relaxed text-center text-paper/80 md:text-xl"
      >
        Definition captures what your organisation knows. Execution makes that
        knowledge available to governed AI systems. Together, they turn
        expertise into operational infrastructure.
      </p>

      <div class="mt-12 flex items-center justify-center">
        <a
          href="#uses"
          class="inline-flex items-center justify-center gap-3 rounded-md bg-[#ff8c69] px-8 py-3 text-sm font-semibold tracking-[0.14em] uppercase text-paper shadow-outline hover:bg-[#e97d5d] transition-colors"
          aria-label="Explore the next section"
        >
          <span>Keep Exploring</span>
          <svg
            class="h-6 w-6 text-paper"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M10 3a1 1 0 0 1 1 1v10.586l2.293-2.293a1 1 0 1 1 1.414 1.414l-4.007 4.007a1 1 0 0 1-1.414 0L6.279 13.707a1 1 0 1 1 1.414-1.414L10 14.586V4a1 1 0 0 1 1-1z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- 4. IBOM Framework (tabs) -->
  <section id="uses" class="bg-paper">
    <div class="container-wide py-20">
      <h2
        class="text-center text-[clamp(2.5rem,5vw,4.75rem)] font-semibold tracking-tight text-ink"
      >
        IBOM Framework
      </h2>

      <div class="mt-10">
        <div
          id="uses-tabs"
          role="tablist"
          aria-label="Advanced Analytica IBOM Uses"
          class="flex w-full flex-wrap items-center justify-between gap-1 rounded-md bg-fog p-2"
        >
          {
            usesTabs.map((t) => (
              <button
                type="button"
                role="tab"
                aria-selected={t.key === defaultUsesKey ? "true" : "false"}
                aria-controls={`uses-panel-${t.key}`}
                id={`uses-tab-${t.key}`}
                data-tab={t.key}
                class="flex-1 rounded-md px-5 py-3 text-base font-medium text-ink/80 transition-colors hover:text-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-[#ef27f4]/70 aria-selected:bg-[#ef27f4] aria-selected:text-paper aria-selected:shadow-sm"
              >
                {t.label}
              </button>
            ))
          }
        </div>
      </div>

      <div
        class="mt-14 grid gap-12 lg:gap-24 lg:grid-cols-[420px_1fr] lg:items-start"
      >
        <div
          class="relative overflow-hidden rounded-2xl bg-slate shadow-outline"
        >
          <div class="aspect-square">
            {
              usesTabs.map((t) => (
                <img
                  src={t.image}
                  alt=""
                  aria-hidden="true"
                  data-visual={t.key}
                  hidden={t.key === defaultUsesKey ? undefined : true}
                  class="h-full w-full object-cover"
                  decoding="async"
                  loading="lazy"
                />
              ))
            }
          </div>
        </div>

        <div class="max-w-prose pt-2">
          {
            usesTabs.map((t) => (
              <div
                role="tabpanel"
                id={`uses-panel-${t.key}`}
                aria-labelledby={`uses-tab-${t.key}`}
                data-panel={t.key}
                hidden={t.key === defaultUsesKey ? undefined : true}
              >
                <div class="text-xs font-semibold tracking-[0.2em] uppercase text-steel">
                  {t.lead}
                </div>
                <div class="mt-4 text-2xl md:text-3xl font-semibold tracking-[0.08em] uppercase text-[#ef27f4]">
                  {t.heading}
                </div>
                <div class="mt-6 text-lg md:text-xl font-medium leading-snug text-ink">
                  {t.subheading}
                </div>
                <p class="mt-5 text-base leading-relaxed text-ink/80">
                  {t.body}
                </p>

                <a
                  href={t.href}
                  target={t.external ? "_blank" : undefined}
                  rel={t.external ? "noopener noreferrer" : undefined}
                  class="mt-12 inline-flex items-center gap-2 text-base font-semibold tracking-[0.14em] uppercase text-ink hover:text-accent transition-colors"
                >
                  {t.cta}
                  <svg
                    class="h-4 w-4"
                    viewBox="0 0 20 20"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M4 10h12" />
                    <path d="M12 6l4 4-4 4" />
                  </svg>
                </a>
              </div>
            ))
          }
        </div>
      </div>

      <div class="mt-12 flex items-center justify-center">
        <a
          href="#for"
          class="inline-flex items-center justify-center gap-3 rounded-md bg-[#ff8c69] px-8 py-3 text-sm font-semibold tracking-[0.14em] uppercase text-paper shadow-outline hover:bg-[#e97d5d] transition-colors"
          aria-label="Explore the next section"
        >
          <span>Keep Exploring</span>
          <svg
            class="h-6 w-6 text-paper"
            viewBox="0 0 20 20"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M10 3a1 1 0 0 1 1 1v10.586l2.293-2.293a1 1 0 1 1 1.414 1.414l-4.007 4.007a1 1 0 0 1-1.414 0L6.279 13.707a1 1 0 1 1 1.414-1.414L10 14.586V4a1 1 0 0 1 1-1z"
            ></path>
          </svg>
        </a>
      </div>
    </div>

    <script is:inline define:vars={{ defaultUsesKey }}>
      (() => {
        const tablist = document.getElementById("uses-tabs");
        if (!tablist) return;

        const tabs = Array.from(tablist.querySelectorAll('[role="tab"]'));
        const panels = new Map(
          Array.from(document.querySelectorAll("[data-panel]")).map((el) => [
            el.getAttribute("data-panel"),
            el,
          ]),
        );
        const visuals = new Map(
          Array.from(document.querySelectorAll("[data-visual]")).map((el) => [
            el.getAttribute("data-visual"),
            el,
          ]),
        );

        const activate = (key, focus = false) => {
          tabs.forEach((t) => {
            const selected = t.getAttribute("data-tab") === key;
            t.setAttribute("aria-selected", selected ? "true" : "false");
            t.tabIndex = selected ? 0 : -1;
          });
          panels.forEach((panel, panelKey) => {
            panel.hidden = panelKey !== key;
          });
          visuals.forEach((visual, visualKey) => {
            visual.hidden = visualKey !== key;
          });
          if (focus)
            tabs.find((t) => t.getAttribute("data-tab") === key)?.focus();
        };

        const selected =
          tabs.find((t) => t.getAttribute("aria-selected") === "true") ||
          tabs[0];
        activate(selected?.getAttribute("data-tab") || defaultUsesKey);

        tabs.forEach((t) => {
          t.addEventListener("click", () =>
            activate(t.getAttribute("data-tab"), true),
          );
          t.addEventListener("keydown", (e) => {
            if (
              e.key !== "ArrowLeft" &&
              e.key !== "ArrowRight" &&
              e.key !== "Home" &&
              e.key !== "End"
            )
              return;
            e.preventDefault();
            const currentIndex = tabs.indexOf(t);
            const nextIndex =
              e.key === "Home"
                ? 0
                : e.key === "End"
                  ? tabs.length - 1
                  : e.key === "ArrowRight"
                    ? (currentIndex + 1) % tabs.length
                    : (currentIndex - 1 + tabs.length) % tabs.length;
            const next = tabs[nextIndex];
            activate(next.getAttribute("data-tab"), true);
          });
        });
      })();
    </script>
  </section>

  <!-- 5. WHO IBOM IS FOR -->
  <section id="for" class="bg-slate text-paper">
    <div class="container-wide py-20">
      <h2
        class="text-center text-[clamp(2.5rem,5vw,4.75rem)] font-semibold tracking-tight text-paper"
      >
        The IBOM Advantage
      </h2>
      <p
        class="mx-auto mt-10 max-w-[80ch] text-center text-lg leading-relaxed text-paper/80 md:text-xl"
      >
