---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_URL } from '../../lib/seo/site';

const title = 'IBOM™';
const description = 'This page has moved.';

const targetPath = '/services/ibom/';
const targetUrl = `${SITE_URL}${targetPath}`;

const page = {
  title,
  description,
  url: targetUrl,
  breadcrumbs: [
    { name: 'Home', url: `${SITE_URL}/` },
    { name: 'Services', url: `${SITE_URL}/services/` },
    { name: 'IBOM™', url: targetUrl }
  ]
};
---
<BaseLayout title={title} description={description} page={page}>
  <Fragment slot="head">
    <meta http-equiv="refresh" content={`0; url=${targetPath}`} />
  </Fragment>

  <section class="container-wide py-16">
    <h1 class="text-3xl font-semibold tracking-tight text-ink">Redirecting…</h1>
    <p class="mt-4 text-steel">
      This page has moved to <a class="underline hover:text-ink" href={targetPath}>IBOM™</a>.
    </p>
  </section>

  <script is:inline>
    (() => {
      const target = "/services/ibom/";
      if (typeof window !== "undefined") window.location.replace(target);
    })();
  </script>
</BaseLayout>

