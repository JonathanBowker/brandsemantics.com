---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_URL } from '../../lib/seo/site';

const title = 'IBOM<sup>®</sup>';
const description = 'The Intelligent Brand Operating Model for executable brand systems.';

const page = {
  title,
  description,
  url: `${SITE_URL}/services/ibom`,
  breadcrumbs: [
    { name: 'Home', url: `${SITE_URL}/` },
    { name: 'Services', url: `${SITE_URL}/services/` },
    { name: 'IBOM<sup>®</sup>', url: `${SITE_URL}/services/ibom` }
  ]
};
---
<BaseLayout title={title} description={description} page={page}>
  <section class="container-wide py-16">
    <div class="eyebrow">Operating Model</div>
    <h1 class="mt-4 text-4xl font-semibold text-ink">IBOM<sup>®</sup></h1>
    <p class="mt-4 text-base text-steel">
      IBOM<sup>®</sup> is the operating model that turns brand meaning into executable systems: structured data,
      policy logic, and accountable delivery.
    </p>
  </section>

  <section class="container-wide pb-16">
    <div class="grid gap-6 lg:grid-cols-3">
      <div class="rounded-xl border border-fog bg-surface p-6">
        <div class="text-sm font-semibold text-ink">Semantic architecture</div>
        <p class="mt-3 text-sm text-steel">Define brand meaning as governed data models and schema.</p>
      </div>
      <div class="rounded-xl border border-fog bg-surface p-6">
        <div class="text-sm font-semibold text-ink">Executable policy</div>
        <p class="mt-3 text-sm text-steel">Translate guidelines into enforceable rules and checks.</p>
      </div>
      <div class="rounded-xl border border-fog bg-surface p-6">
        <div class="text-sm font-semibold text-ink">Operational delivery</div>
        <p class="mt-3 text-sm text-steel">Ship standards through developer-ready interfaces.</p>
      </div>
    </div>
  </section>

  <section class="container-wide pb-20">
    <div class="rounded-2xl border border-fog bg-surface p-8">
      <div class="eyebrow">Design System Overview</div>
      <h2 class="mt-4 text-2xl font-semibold text-ink">Design systems as governance infrastructure</h2>
      <p class="mt-4 text-sm text-steel">
        The Advanced Analytica design system overview explains how product design systems map to IBOM<sup>®</sup>.
        It focuses on principles, governance, and execution rather than exhaustive component specs.
      </p>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        <div class="rounded-lg border border-fog p-4">
          <div class="text-sm font-semibold text-ink">Principles first</div>
          <p class="mt-2 text-xs text-steel">Establish shared meaning before visual tokens.</p>
        </div>
        <div class="rounded-lg border border-fog p-4">
          <div class="text-sm font-semibold text-ink">Governed interfaces</div>
          <p class="mt-2 text-xs text-steel">Define who can change what, and how changes propagate.</p>
        </div>
        <div class="rounded-lg border border-fog p-4">
          <div class="text-sm font-semibold text-ink">Executable standards</div>
          <p class="mt-2 text-xs text-steel">Policies enforce what the system should output.</p>
        </div>
        <div class="rounded-lg border border-fog p-4">
          <div class="text-sm font-semibold text-ink">Auditability</div>
          <p class="mt-2 text-xs text-steel">Track compliance as systems evolve.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
