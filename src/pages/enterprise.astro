---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE_URL } from '../lib/seo/site';

const title = 'Enterprise';
const description = 'Governance-ready brand systems for complex enterprises.';

const useCases = await getCollection('useCases', ({ data }) => !data.draft);

const page = {
  title,
  description,
  url: `${SITE_URL}/enterprise`,
  breadcrumbs: [
    { name: 'Home', url: `${SITE_URL}/` },
    { name: 'Enterprise', url: `${SITE_URL}/enterprise` }
  ]
};
---
<BaseLayout title={title} description={description} page={page}>
  <section class="container-wide py-16">
    <div class="eyebrow">Enterprise</div>
    <h1 class="mt-4 text-4xl font-semibold text-ink">Governance at scale</h1>
    <p class="mt-4 text-base text-steel">
      Advanced Analytica supports enterprises with multi-team, multi-market governance requirements.
      IBOM<sup>®</sup> provides the operating layer that keeps execution consistent and auditable.
    </p>
  </section>

  <section class="container-wide pb-20">
    <div class="grid gap-6 lg:grid-cols-3">
      {useCases.map((useCase) => (
        <article class="rounded-xl border border-fog bg-surface p-6">
          <div class="text-xs uppercase tracking-[0.2em] text-steel">{useCase.data.industry}</div>
          <h2 class="mt-3 text-xl font-semibold text-ink">{useCase.data.title}</h2>
          <p class="mt-3 text-sm text-steel">{useCase.data.description}</p>
          {useCase.data.outcomes && (
            <ul class="mt-4 list-disc pl-5 text-xs text-steel">
              {useCase.data.outcomes.map((outcome) => (
                <li>{outcome}</li>
              ))}
            </ul>
          )}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
