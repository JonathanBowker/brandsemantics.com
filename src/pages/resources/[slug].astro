---
import BaseLayout from '../../layouts/BaseLayout.astro';
import components from '../../lib/mdx/components';
import { getCollection } from 'astro:content';
import { SITE_URL } from '../../lib/seo/site';

export async function getStaticPaths() {
  const items = await getCollection('resources', ({ data }) => !data.draft);
  return items.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props as { item: Awaited<ReturnType<typeof getCollection>>[number] };
const { Content } = await item.render();

const title = item.data.title;
const description = item.data.description;
const url = `${SITE_URL}/resources/${item.slug}`;

const page = {
  title,
  description,
  url,
  breadcrumbs: [
    { name: 'Home', url: `${SITE_URL}/` },
    { name: 'Resources', url: `${SITE_URL}/resources/` },
    { name: title, url }
  ]
};
---
<BaseLayout title={title} description={description} page={page}>
  <section class="container-wide py-16">
    <a href="/resources" class="text-xs font-semibold tracking-[0.2em] uppercase text-steel hover:text-ink">
      ← Back to Resources
    </a>
    <h1 class="mt-6 text-[clamp(2rem,4vw,3.25rem)] font-semibold tracking-tight text-ink">
      {title}
    </h1>
    <p class="mt-6 max-w-[70ch] text-lg leading-relaxed text-steel">
      {description}
    </p>
    {item.data.tags?.length ? (
      <div class="mt-8 flex flex-wrap gap-3">
        {item.data.tags.map((tag) => (
          <span class="rounded-sm bg-[#ef27f4] px-4 py-2 text-xs font-semibold uppercase text-paper">
            {tag}
          </span>
        ))}
      </div>
    ) : null}
  </section>

  <section class="container-wide pb-20">
    <article class="prose">
      <Content components={components} />
    </article>
  </section>
</BaseLayout>
