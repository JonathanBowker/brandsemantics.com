---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SITE_URL } from '../../../lib/seo/site';
export async function getStaticPaths() {
  const posts = await getCollection('caseStudies', ({ data }) => !data.draft);
  const tags = Array.from(new Set(posts.flatMap((p) => p.data.tags ?? [])));
  return tags.map((tag) => ({ params: { tag: encodeURIComponent(tag) }, props: { tag } }));
}
const { tag } = Astro.props as { tag: string };
const title = `Use Cases: ${tag}`;
const description = 'This page has moved.';
const targetPath = `/use-cases/tag/${encodeURIComponent(tag)}/`;
const targetUrl = `${SITE_URL}${targetPath}`;
const page = {
  title,
  description,
  url: targetUrl,
  breadcrumbs: [
    { name: 'Home', url: `${SITE_URL}/` },
    { name: 'Use Cases', url: `${SITE_URL}/use-cases/` },
    { name: tag, url: targetUrl }
  ]
};
---
<BaseLayout title={title} description={description} page={page}>
  <Fragment slot="head">
    <meta http-equiv="refresh" content={`0; url=${targetPath}`} />
  </Fragment>

  <section class="container-wide py-16">
    <h1 class="text-3xl font-semibold tracking-tight text-ink">Redirecting…</h1>
    <p class="mt-4 text-steel">
      This page has moved to <a class="underline hover:text-ink" href={targetPath}>{title}</a>.
    </p>
  </section>

  <script is:inline define:vars={{ targetPath }}>
    (() => {
      if (typeof window !== "undefined") window.location.replace(targetPath);
    })();
  </script>
</BaseLayout>
