---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BRANDO_SCHEMA_URL, SITE_URL } from '../../lib/seo/site';

const title = 'About';
const description = 'Advanced Analytica helps organisations turn knowledge, policy, and process into governed AI-ready systems.';

const page = {
  title,
  description,
  url: `${SITE_URL}/company/about`,
  breadcrumbs: [
    { name: 'Home', url: `${SITE_URL}/` },
    { name: 'Company', url: `${SITE_URL}/company/about` },
    { name: 'About', url: `${SITE_URL}/company/about` }
  ]
};
---
<BaseLayout title={title} description={description} page={page}>
  <section class="relative overflow-hidden bg-slate text-paper">
    <div class="absolute inset-0 bg-gradient-to-b from-black/30 via-black/10 to-black/45" aria-hidden="true"></div>

    <div class="container-wide relative z-10 pt-28 pb-24">
      <div class="grid gap-12 lg:grid-cols-[1.15fr_0.85fr] lg:items-start">
        <div>
          <div class="eyebrow text-paper/70">Company</div>
          <h1 class="mt-5 font-masthead text-[clamp(2.75rem,5.4vw,5rem)] font-normal tracking-tight text-paper leading-[1.02]">
            Advanced Analytica
          </h1>
          <p class="mt-8 max-w-[80ch] text-lg leading-relaxed text-paper/80 md:text-xl">
            We help organisations turn knowledge, policy, and operational logic
            into governed systems that AI can use safely, consistently, and at
            scale.
          </p>
          <p class="mt-4 max-w-[80ch] text-base leading-relaxed text-paper/70 md:text-lg">
            Our work sits between strategy and execution: defining what matters,
            structuring it clearly, and building the delivery layer that makes
            it usable in live AI-assisted operations.
          </p>

          <div class="mt-10 flex flex-wrap gap-4">
            <a
              href="#get-in-touch"
              class="inline-flex items-center gap-2 rounded-md bg-[#ef27f4] px-8 py-3 text-xs font-semibold tracking-[0.14em] uppercase text-paper shadow-outline hover:bg-[#d823dd] transition-colors"
            >
              Get in touch
              <svg
                class="h-4 w-4"
                viewBox="0 0 20 20"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M4 10h12" />
                <path d="M12 6l4 4-4 4" />
              </svg>
            </a>
            <a
              href="/company/security"
              class="rounded-md border border-[#ff8c69] bg-transparent px-8 py-3 text-xs font-semibold tracking-[0.14em] uppercase text-[#ff8c69] hover:bg-[#ff8c69] hover:text-ink transition-colors"
            >
              Security posture
            </a>
          </div>
        </div>

        <div class="rounded-2xl border border-paper/15 bg-black/20 backdrop-blur p-8 shadow-outline">
          <div class="text-lg font-semibold tracking-[0.2em] uppercase text-paper/70">What we focus on</div>
          <p class="mt-5 text-sm leading-relaxed text-paper/70">
            We work where organisations need expert knowledge, business rules,
            and governance controls to become operational inputs for AI systems.
          </p>
          <div class="mt-6 grid gap-5 text-base leading-relaxed text-paper/75">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded-sm bg-[#ff8c69] px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.2em] text-ink">Knowledge</span>
                <div class="text-sm font-semibold text-paper">What the organisation knows</div>
              </div>
              <div class="mt-2 text-sm">Policies, processes, standards, documents, and specialist expertise.</div>
            </div>
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded-sm bg-[#ef27f4] px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.2em] text-paper">Structure</span>
                <div class="text-sm font-semibold text-paper">How it is defined clearly</div>
              </div>
              <div class="mt-2 text-sm">Specifications, schemas, datasets, linked records, and machine-readable logic.</div>
            </div>
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded-sm bg-[#ff8c69] px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.2em] text-ink">Delivery</span>
                <div class="text-sm font-semibold text-paper">How systems can use it</div>
              </div>
              <div class="mt-2 text-sm">APIs, MCP servers, internal tools, and governed runtime workflows.</div>
            </div>
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <span class="rounded-sm bg-[#ef27f4] px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.2em] text-paper">Control</span>
                <div class="text-sm font-semibold text-paper">How it is governed in use</div>
              </div>
              <div class="mt-2 text-sm">Ownership, approvals, traceability, testing, and controlled change over time.</div>
            </div>
          </div>
          <div class="mt-8 flex flex-wrap gap-2">
            <a
              href="/use-cases"
              class="rounded-md bg-[#ef27f4] px-4 py-2 text-xs font-semibold uppercase text-paper shadow-outline hover:bg-[#d823dd] transition-colors"
            >
              Use cases
            </a>
            <a
              href="/resources"
              class="rounded-md border border-[#ff8c69] bg-transparent px-4 py-2 text-xs font-semibold uppercase text-[#ff8c69] hover:bg-[#ff8c69] hover:text-ink transition-colors"
            >
              Resources
            </a>
            <a
              href="/blog"
              class="rounded-md bg-[#ef27f4] px-4 py-2 text-xs font-semibold uppercase text-paper shadow-outline hover:bg-[#d823dd] transition-colors"
            >
              Opinions
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide py-20">
    <div class="grid gap-6 lg:grid-cols-3">
        <div class="rounded-2xl border border-fog bg-surface p-8 shadow-outline">
          <div class="text-xs font-semibold tracking-[0.2em] uppercase text-steel">Operating model</div>
          <div class="mt-4 text-2xl font-semibold tracking-tight text-ink">IBOM<sup>®</sup></div>
          <p class="mt-4 text-base leading-relaxed text-steel">
            A structured lifecycle for turning organisational intent into clear
            specifications, governed systems, and live operational delivery.
          </p>
        </div>
      <div class="rounded-2xl border border-fog bg-surface p-8 shadow-outline">
        <div class="text-xs font-semibold tracking-[0.2em] uppercase text-steel">Foundation</div>
        <div class="mt-4 text-2xl font-semibold tracking-tight text-ink">Brando Schema</div>
        <p class="mt-4 text-base leading-relaxed text-steel">
          An open semantic foundation for expressing knowledge, policy,
          relationships, and governance in structured form.
        </p>
        <a
          class="mt-6 inline-flex items-center gap-2 text-xs font-semibold tracking-[0.2em] uppercase text-ink hover:text-accent transition-colors"
          href={BRANDO_SCHEMA_URL}
          target="_blank"
          rel="noopener noreferrer"
        >
          Visit Brando Schema <span aria-hidden="true">→</span>
        </a>
      </div>
      <div class="rounded-2xl border border-fog bg-surface p-8 shadow-outline">
        <div class="text-xs font-semibold tracking-[0.2em] uppercase text-steel">Execution</div>
        <div class="mt-4 text-2xl font-semibold tracking-tight text-ink">Governed delivery</div>
        <p class="mt-4 text-base leading-relaxed text-steel">
          Controlled access, supervised build processes, and auditability so AI
          systems can operate against trusted knowledge and defined rules.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-paper">
    <div class="container-wide py-20">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <div class="eyebrow">What we deliver</div>
          <h2 class="mt-4 text-[clamp(2rem,4.2vw,3.5rem)] font-semibold tracking-tight text-ink">
            Practical governance you can ship
          </h2>
          <p class="mt-6 max-w-[80ch] text-lg leading-relaxed text-steel md:text-xl">
            IBOM starts with what the organisation already has: knowledge,
            rules, processes, and expert judgement. The work is turning that
            material into clear specifications, structured assets, and governed
            delivery systems that AI can use reliably in live operation.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {[
            { title: 'Knowledge capture', body: 'Structured capture of business rules, workflows, documents, and specialist judgement.' },
            { title: 'Technical specification', body: 'Clear definitions that experts can validate and AI systems can act on.' },
            { title: 'System boundaries', body: 'Defined scope for what can and cannot be automated safely.' },
            { title: 'Connection layer', body: 'Governed APIs, MCP services, and retrieval patterns that expose trusted knowledge.' },
            { title: 'Operational controls', body: 'Checks, approval logic, and audit trails that run in live delivery.' },
            { title: 'Change control', body: 'Versioned updates, owners, and traceability so systems evolve safely over time.' }
          ].map((item) => (
            <div class="rounded-2xl border border-fog bg-surface p-6 shadow-outline">
              <div class="text-xs font-semibold tracking-[0.2em] uppercase text-steel">{item.title}</div>
              <p class="mt-3 text-sm leading-relaxed text-steel">{item.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide py-20">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-start">
      <div>
          <div class="eyebrow">Where it fits</div>
          <h2 class="mt-4 text-[clamp(2rem,4.2vw,3.25rem)] font-semibold tracking-tight text-ink">
            Integrated, not isolated
          </h2>
          <p class="mt-6 max-w-[80ch] text-lg leading-relaxed text-steel md:text-xl">
            This work is only useful when it meets the operational surfaces where
            real decisions happen: research, delivery, review, deployment, and
            ongoing management.
          </p>
        </div>

        <div class="grid gap-6">
          {[
          { title: 'Internal knowledge systems', body: 'Governed knowledge bases that teams and AI assistants can query reliably.' },
          { title: 'AI-assisted operations', body: 'Workflows where drafting, decision support, and execution need clear controls.' },
          { title: 'Enterprise tooling', body: 'Internal products, assistants, and connected services that rely on trusted organisational logic.' },
          { title: 'Delivery pipelines', body: 'Build, test, deployment, and review processes where policy needs to be operational.' }
        ].map((item) => (
          <div class="rounded-2xl border border-fog bg-surface p-8 shadow-outline">
            <div class="text-sm font-semibold text-ink">{item.title}</div>
            <p class="mt-3 text-sm leading-relaxed text-steel">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-paper">
    <div class="container-wide py-20">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <div class="eyebrow">How we work</div>
          <h2 class="mt-4 text-[clamp(2rem,4.2vw,3.5rem)] font-semibold tracking-tight text-ink">
            From intent to operation
          </h2>
          <p class="mt-6 text-lg leading-relaxed text-steel md:text-xl">
            We treat organisational knowledge as an operational asset: defined
            clearly, structured properly, connected to systems, and governed in
            use.
          </p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
          {[
            { title: 'Assessment', body: 'Clarify objectives, risks, operating realities, and the use cases worth solving.' },
            { title: 'Definition', body: 'Turn tacit business logic into explicit requirements, rules, and instructions.' },
            { title: 'Codification', body: 'Express that logic in structured, machine-readable forms.' },
            { title: 'Deployment', body: 'Connect governed knowledge to products, services, and delivery environments.' },
            { title: 'Operation', body: 'Run systems with oversight, monitoring, and accountable decision pathways.' },
            { title: 'Assurance', body: 'Test outcomes, track performance, and update safely as needs change.' }
          ].map((step) => (
            <div class="rounded-2xl border border-fog bg-surface p-6 shadow-outline">
              <div class="text-xs font-semibold tracking-[0.2em] uppercase text-steel">{step.title}</div>
              <p class="mt-3 text-sm leading-relaxed text-steel">{step.body}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="container-wide py-20">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-start">
      <div>
          <div class="eyebrow">Principles</div>
          <h2 class="mt-4 text-[clamp(2rem,4.2vw,3.25rem)] font-semibold tracking-tight text-ink">
            Governance you can operate
          </h2>
          <p class="mt-6 max-w-[80ch] text-lg leading-relaxed text-steel md:text-xl">
            The value of governance is not more documentation. It is reliable
            behaviour, clear ownership, and systems that can scale without
            becoming opaque or fragile.
          </p>
        </div>

      <div class="grid gap-6">
        {[
          { title: 'Knowledge-first', body: 'Start with what the organisation actually knows, not with generic tooling.' },
          { title: 'Executable definition', body: 'Specifications should be usable by both experts and systems.' },
          { title: 'Auditable decisions', body: 'Approvals, exceptions, and outputs must be traceable.' },
          { title: 'Measured assurance', body: 'Quality, drift, and policy adherence should become operational signals.' }
        ].map((item) => (
          <div class="rounded-2xl border border-fog bg-surface p-8 shadow-outline">
            <div class="text-sm font-semibold text-ink">{item.title}</div>
            <p class="mt-3 text-sm leading-relaxed text-steel">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
