---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_URL } from '../../lib/seo/site';

const title = 'Contact';
const description = 'Start a governance conversation with Brand Semantics.';

const page = {
  title,
  description,
  url: `${SITE_URL}/company/contact`,
  breadcrumbs: [
    { name: 'Home', url: `${SITE_URL}/` },
    { name: 'Company', url: `${SITE_URL}/company/about` },
    { name: 'Contact', url: `${SITE_URL}/company/contact` }
  ]
};
---
<BaseLayout title={title} description={description} page={page}>
  <section class="container-wide py-16">
    <div class="eyebrow">Company</div>
    <h1 class="mt-4 text-4xl font-semibold text-ink">Get in touch</h1>
    <p class="mt-4 text-lg text-steel max-w-prose">
      Use this form to generate a briefing request email with the right context. Nothing is stored on the site.
    </p>

    <div class="mt-12 grid gap-10 lg:grid-cols-[1fr_1.2fr] lg:items-start">
      <div class="rounded-2xl border border-fog bg-surface p-8 shadow-outline">
        <div class="text-xs font-semibold tracking-[0.2em] uppercase text-steel">What to include</div>
        <ul class="mt-6 space-y-3 text-base leading-relaxed text-steel">
          <li>Your objective and audience</li>
          <li>AI systems and channels in scope</li>
          <li>Risk constraints (legal, regulated content, safety)</li>
          <li>Who owns approvals and change control</li>
        </ul>
        <div class="mt-8 text-xs font-semibold tracking-[0.2em] uppercase text-steel">Note</div>
        <p class="mt-3 text-base leading-relaxed text-steel">
          Submitting opens your email client with a prefilled message. If you prefer, copy/paste the details into your internal procurement channel.
        </p>
      </div>

      <div class="rounded-2xl border border-fog bg-surface p-8 shadow-outline">
        <form id="contact-form" class="grid gap-5" novalidate>
          <div class="grid gap-2">
            <label for="name" class="text-base font-semibold text-ink">Name</label>
            <input
              id="name"
              name="name"
              type="text"
              autocomplete="name"
              required
              class="rounded-md border border-fog bg-paper px-4 py-3 text-base text-ink outline-none focus:border-accent focus:ring-2 focus:ring-accent/30"
            />
          </div>

          <div class="grid gap-2">
            <label for="email" class="text-base font-semibold text-ink">Email</label>
            <input
              id="email"
              name="email"
              type="email"
              autocomplete="email"
              inputmode="email"
              required
              class="rounded-md border border-fog bg-paper px-4 py-3 text-base text-ink outline-none focus:border-accent focus:ring-2 focus:ring-accent/30"
            />
          </div>

          <div class="grid gap-5 md:grid-cols-2">
            <div class="grid gap-2">
              <label for="company" class="text-base font-semibold text-ink">Company</label>
              <input
                id="company"
                name="company"
                type="text"
                autocomplete="organization"
                class="rounded-md border border-fog bg-paper px-4 py-3 text-base text-ink outline-none focus:border-accent focus:ring-2 focus:ring-accent/30"
              />
            </div>
            <div class="grid gap-2">
              <label for="topic" class="text-base font-semibold text-ink">Topic</label>
              <select
                id="topic"
                name="topic"
                required
                class="rounded-md border border-fog bg-paper px-4 py-3 text-base text-ink outline-none focus:border-accent focus:ring-2 focus:ring-accent/30"
              >
                <option value="">Select…</option>
                <option>IBOM lifecycle</option>
                <option>Enterprise governance</option>
                <option>Developers / MCP</option>
                <option>Publishing / schema</option>
                <option>Security / assurance</option>
              </select>
            </div>
          </div>

          <div class="grid gap-2">
            <label for="message" class="text-base font-semibold text-ink">Message</label>
            <textarea
              id="message"
              name="message"
              rows="6"
              required
              class="rounded-md border border-fog bg-paper px-4 py-3 text-base text-ink outline-none focus:border-accent focus:ring-2 focus:ring-accent/30"
            ></textarea>
          </div>

          <div class="flex flex-wrap items-center justify-between gap-4 pt-2">
            <div id="contact-status" class="text-base text-steel" aria-live="polite"></div>
            <button
              type="submit"
              class="rounded-md border border-strandOrange/80 bg-transparent px-6 py-3 text-xs font-semibold tracking-[0.14em] uppercase text-strandOrange transition-colors hover:bg-strandOrange hover:text-ink"
            >
              Generate Email
            </button>
          </div>

          <noscript>
            <p class="text-base text-steel">
              JavaScript is required to generate the email draft. You can still email us by copying your details into your preferred channel.
            </p>
          </noscript>
        </form>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const form = document.getElementById("contact-form");
      const status = document.getElementById("contact-status");
      if (!form) return;

      const setStatus = (msg) => {
        if (status) status.textContent = msg;
      };

      form.addEventListener("submit", (e) => {
        e.preventDefault();

        const fd = new FormData(form);
        const name = String(fd.get("name") || "").trim();
        const email = String(fd.get("email") || "").trim();
        const company = String(fd.get("company") || "").trim();
        const topic = String(fd.get("topic") || "").trim();
        const message = String(fd.get("message") || "").trim();

        if (!name || !email || !topic || !message) {
          setStatus("Please complete the required fields.");
          return;
        }

        const subject = `Brand Semantics briefing request: ${topic}`;
        const body = [
          `Name: ${name}`,
          `Email: ${email}`,
          company ? `Company: ${company}` : "",
          `Topic: ${topic}`,
          "",
          "---",
          "",
          message
        ]
          .filter(Boolean)
          .join("\n");

        // No address on purpose (avoids inventing). User can route internally.
        const mailto = `mailto:?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

        setStatus("Opening email draft…");
        window.location.href = mailto;
      });
    })();
  </script>
</BaseLayout>
