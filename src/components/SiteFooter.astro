---
const links = [
  { label: "About", href: "/company/about" },
  { label: "Security", href: "/company/security" },
  { label: "Contact", href: "/company/contact" },
  { label: "Privacy", href: "/legal/privacy" },
  { label: "Terms", href: "/legal/terms" },
];
---

<section class="bg-ink text-paper">
  <div class="container-wide py-20">
    <div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div>
        <div class="eyebrow text-paper/70">Next step</div>
        <h2
          class="mt-4 text-[clamp(2.2rem,4.6vw,3.75rem)] font-semibold tracking-tight text-paper"
        >
          Ready to make your logic executable?
        </h2>
        <p
          class="mt-6 max-w-[80ch] text-lg leading-relaxed text-paper/80 md:text-xl"
        >
          Share your thoughts about what you’re building, where AI engages with
          your brand, and what needs controlling. We can help you clarify and
          scope your next steps.
        </p>
      </div>

      <div class="flex flex-col gap-4">
        <a
          href="#get-in-touch"
          class="inline-flex items-center justify-center gap-2 rounded-md bg-strandGreen px-8 py-4 text-xs font-semibold tracking-[0.14em] uppercase text-ink shadow-outline hover:bg-strandGreen/90 transition-colors"
        >
          Get in touch
          <svg
            class="h-4 w-4"
            viewBox="0 0 20 20"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 10h12" />
            <path d="M12 6l4 4-4 4" />
          </svg>
        </a>
        <a
          href="/use-cases"
          class="inline-flex items-center justify-center rounded-md border border-paper/20 bg-transparent px-8 py-4 text-xs font-semibold tracking-[0.14em] uppercase text-paper hover:border-paper/40 transition-colors"
        >
          View use cases
        </a>
      </div>
    </div>
  </div>
</section>

<section
  id="get-in-touch"
  class="bg-[url('/images/get-in-touch/bgimage.webp')] bg-cover bg-center"
>
  <div>
    <div class="container-wide py-24">
      <div class="grid overflow-hidden shadow-outline lg:grid-cols-[1fr_1fr]">
        <div class="relative min-h-[440px] overflow-hidden">
          <div class="absolute inset-0 bg-cover bg-center"></div>
          <div class="relative z-10 h-full">
            <div class="absolute inset-x-0 bottom-0 bg-strandGreen">
              <div class="m-8 max-w-[360px] px-10 pb-6 text-ink">
                <div class="text-8xl font-semibold tracking-tight">
                  Get in touch.
                </div>
              </div>
            </div>
          </div>
        </div>

        <div
          class="bg-paper p-12 lg:-mr-[calc(50vw-50%)] lg:pr-[calc(50vw-50%)]"
        >
          <form
            id="home-contact-form"
            class="grid gap-6 max-w-[520px]"
            novalidate
          >
            <div class="grid gap-2">
              <label for="home-name" class="text-base font-semibold text-ink/70"
                >Name</label
              >
              <input
                id="home-name"
                name="name"
                type="text"
                autocomplete="name"
                required
                class="border-b border-fog bg-transparent pb-3 text-base text-ink outline-none focus:border-ink"
              />
            </div>

            <div class="grid gap-2">
              <label
                for="home-email"
                class="text-base font-semibold text-ink/70">Email*</label
              >
              <input
                id="home-email"
                name="email"
                type="email"
                autocomplete="email"
                inputmode="email"
                required
                class="border-b border-fog bg-transparent pb-3 text-base text-ink outline-none focus:border-ink"
              />
            </div>

            <div class="grid gap-2">
              <label
                for="home-subject"
                class="text-base font-semibold text-ink/70">Subject*</label
              >
              <input
                id="home-subject"
                name="topic"
                type="text"
                required
                class="border-b border-fog bg-transparent pb-3 text-base text-ink outline-none focus:border-ink"
              />
            </div>

            <div class="grid gap-2">
              <label
                for="home-message"
                class="text-base font-semibold text-ink/70">Message</label
              >
              <textarea
                id="home-message"
                name="message"
                rows="4"
                required
                class="border-b border-fog bg-transparent pb-3 text-base text-ink outline-none focus:border-ink"
              ></textarea>
            </div>

            <div class="pt-2">
              <div class="flex justify-end pr-10">
                <button
                  type="submit"
                  class="rounded-md bg-ink px-8 py-3 text-sm font-semibold text-paper"
                >
                  Submit
                </button>
              </div>
              <div
                id="home-contact-status"
                class="mt-3 text-sm text-steel"
                aria-live="polite"
              >
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="relative overflow-hidden bg-slate text-paper">
  <div class="absolute inset-0 bg-slate" aria-hidden="true"></div>

  <div class="container-wide relative z-10 py-20">
    <div class="mx-auto max-w-[980px]">
      <img
        src="/images/partners/logo.png"
        alt="Advanced Analytica"
        loading="lazy"
        class="mx-auto h-10 w-auto opacity-100 md:h-12"
      />

      <div
        class="mt-10 grid gap-4 text-base leading-relaxed text-paper/85 md:text-lg"
      >
        <p>
          Modern enterprises face challenges that traditional approaches can't
          solve. They require world-class solutions that integrate people,
          processes, information, and technology—precisely when needed.
        </p>
        <p>
          Advanced Analytica partners with these organisations to protect and
          capitalise on data and AI, manage risk, deliver transparency, and
          control costs. With enterprise-level expertise and three decades of
          industry experience, Advanced Analytica creates measurable value
          through innovative technology and intelligent automation that
          transforms data into a strategic asset.
        </p>
        <p class="mx-auto h-10 w-auto md:h-12">Supported by</p>
      </div>
      <div>
        <img
          src="/images/partners/aa_support.svg"
          alt="Advanced Analytica"
          loading="lazy"
          class="mx-auto h-10 w-auto opacity-90 md:h-12"
        />
      </div>
    </div>
  </div>
</section>

<footer class="border-t border-paper/10 bg-ink text-paper">
  <div class="container-wide flex flex-col gap-6 py-10 text-sm text-paper/70">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div class="text-xs font-semibold tracking-[0.2em] uppercase text-paper">
        Advanced Analytica
      </div>
      <div class="flex flex-wrap gap-4">
        {
          links.map((item) => (
            <a href={item.href} class="hover:text-paper transition-colors">
              {item.label}
            </a>
          ))
        }
      </div>
    </div>
    <div class="text-xs">© {new Date().getFullYear()} Advanced Analytica.</div>
  </div>
</footer>

<script is:inline>
  (() => {
    const form = document.getElementById("home-contact-form");
    const status = document.getElementById("home-contact-status");
    if (!form) return;

    const setStatus = (msg) => {
      if (status) status.textContent = msg;
    };

    form.addEventListener("submit", (e) => {
      e.preventDefault();

      const fd = new FormData(form);
      const name = String(fd.get("name") || "").trim();
      const email = String(fd.get("email") || "").trim();
      const topic = String(fd.get("topic") || "").trim();
      const message = String(fd.get("message") || "").trim();

      if (!name || !email || !topic || !message) {
        setStatus("Please complete the required fields.");
        return;
      }

      const subject = `Advanced Analytica briefing request: ${topic}`;
      const body = [
        `Name: ${name}`,
        `Email: ${email}`,
        `Topic: ${topic}`,
        "",
        "---",
        "",
        message,
      ]
        .filter(Boolean)
        .join("\n");

      const mailto = `mailto:?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

      setStatus("Opening email draft…");
      window.location.href = mailto;
    });
  })();
</script>
